// Homeworks — Prisma schema
// Schéma se rozšiřuje milestone po milestone podle IMPLEMENTATION_PLAN.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  CHILD
}

model User {
  id                  String    @id @default(cuid())
  name                String
  role                Role
  pinHash             String
  avatarColor         String    @default("#888")
  rotationOrder       Int?
  monthlyAllowanceCzk Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sessions               Session[]
  competencyAssignments  CompetencyAssignment[]
  dailyCheckInstances    DailyCheckInstance[]    @relation("DailyCheckInstanceUser")
  reviewedCheckInstances DailyCheckInstance[]    @relation("DailyCheckInstanceReviewer")
  creditTransactions     CreditTransaction[]
  screenTimeRequests     ScreenTimeRequest[]
  weeklyPayouts          WeeklyPayout[]          @relation("WeeklyPayoutUser")
  paidOutByWeeklyPayouts WeeklyPayout[]          @relation("WeeklyPayoutPaidBy")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Competency {
  id          String   @id @default(cuid())
  name        String
  description String?
  order       Int

  dailyChecks DailyCheck[]
  assignments CompetencyAssignment[]
}

enum TimeOfDay {
  MORNING
  EVENING
  ANYTIME
}

model DailyCheck {
  id           String     @id @default(cuid())
  competencyId String
  competency   Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  name         String
  timeOfDay    TimeOfDay
  order        Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  instances    DailyCheckInstance[]

  @@index([competencyId])
}

model CompetencyAssignment {
  id           String     @id @default(cuid())
  competencyId String
  competency   Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart    DateTime
  weekEnd      DateTime

  @@unique([userId, weekStart])
  @@index([weekStart])
}

enum CheckStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  MISSED
}

model DailyCheckInstance {
  id           String      @id @default(cuid())
  dailyCheckId String
  dailyCheck   DailyCheck  @relation(fields: [dailyCheckId], references: [id], onDelete: Cascade)
  userId       String
  user         User        @relation("DailyCheckInstanceUser", fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime
  status       CheckStatus @default(PENDING)
  submittedAt  DateTime?
  reviewedAt   DateTime?
  reviewerId   String?
  reviewer     User?       @relation("DailyCheckInstanceReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([dailyCheckId, userId, date])
  @@index([userId, date])
  @@index([status])
}

model Task {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  valueCzk            Int
  timeEstimateMinutes Int?
  frequencyDays       Int?
  claimTimeoutHours   Int      @default(24)
  executeTimeoutHours Int      @default(3)
  createdById         String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  isActive            Boolean  @default(true)

  instances   TaskInstance[]
  rotationLog TaskRotationLog[]

  @@index([isActive])
}

enum TaskStatus {
  AVAILABLE
  CLAIMED
  PENDING_REVIEW
  DONE
  EXPIRED
  REJECTED
}

model TaskInstance {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime
  status    TaskStatus @default(AVAILABLE)

  // Rotational queue
  rotationQueue   Json   // string[] of userIds in priority order
  rotationIndex   Int    @default(0)
  unlockedForUserId String?
  unlockExpiresAt   DateTime?

  // Claim
  claimedById     String?
  claimedAt       DateTime?
  executeDeadline DateTime?

  // Review
  submittedAt DateTime?
  reviewedAt  DateTime?
  reviewerId  String?
  reviewNote  String?

  @@index([status])
  @@index([taskId])
  @@index([unlockedForUserId])
}

model TaskRotationLog {
  id     String   @id @default(cuid())
  taskId String
  task   Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String
  doneAt DateTime @default(now())

  @@index([taskId, userId])
  @@index([taskId, doneAt])
}

enum NotificationEventType {
  CHECK_SUBMITTED
  TASK_PENDING_REVIEW
  SCREEN_TIME_REQUESTED
}

model NotificationQueue {
  id        String                @id @default(cuid())
  eventType NotificationEventType
  payload   Json
  createdAt DateTime              @default(now())
  sentAt    DateTime?

  @@index([sentAt])
}

model NotificationLog {
  id        String   @id @default(cuid())
  sentAt    DateTime @default(now())
  itemCount Int

  @@index([sentAt])
}

enum TransactionType {
  TASK_REWARD
  SCREEN_TIME
  MONTHLY_BONUS
  PAYOUT
  ADJUSTMENT
}

model CreditTransaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountCzk   Int
  type        TransactionType
  referenceId String?
  weekStart   DateTime
  note        String?
  createdAt   DateTime        @default(now())

  @@index([userId, weekStart])
  @@index([userId, createdAt])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model ScreenTimeRequest {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  minutes    Int
  costCzk    Int
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  reviewedAt DateTime?
  reviewerId String?

  @@index([status])
  @@index([userId])
}

model WeeklyPayout {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation("WeeklyPayoutUser", fields: [userId], references: [id], onDelete: Cascade)
  weekStart          DateTime
  weekEnd            DateTime
  totalEarnedCzk     Int
  totalScreenTimeCzk Int
  bonusCzk           Int       @default(0)
  totalPayoutCzk     Int
  paidOutAt          DateTime?
  paidOutById        String?
  paidOutBy          User?     @relation("WeeklyPayoutPaidBy", fields: [paidOutById], references: [id], onDelete: SetNull)
  createdAt          DateTime  @default(now())

  @@unique([userId, weekStart])
  @@index([weekStart])
}

model AppSettings {
  id                         String @id @default(cuid())
  hourlyRateCzk              Int    @default(150)
  screenTimeHourCostCzk      Int    @default(200)
  screenTimeMinGranularity   Int    @default(30)
  monthlyBonusCzk            Int    @default(200)
  defaultClaimTimeoutHours   Int    @default(24)
  defaultExecuteTimeoutHours Int    @default(3)
  updatedAt                  DateTime @updatedAt
}
