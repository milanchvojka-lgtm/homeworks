# Postgres připojení (Supabase). Stringy z Connect modalu v Supabase Dashboardu.
#
# DATABASE_URL = Transaction Pooler (port 6543, IPv4 proxied).
#   Používá Prisma client za runtime z Vercelu → MUSÍ mít ?pgbouncer=true
#   protože transaction pooler nesnáší prepared statements jinak.
#
# DIRECT_URL = Session Pooler (port 5432, IPv4 proxied).
#   Používá Prisma `migrate` / `db push` pro DDL operace.
DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-eu-central-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-eu-central-2.pooler.supabase.com:5432/postgres"

# Vynucuje běh Node procesu v Europe/Prague (důležité pro cron handlery a date-fns).
TZ="Europe/Prague"

# Sdílený secret pro autorizaci HTTPS volání cron endpointů z GitHub Actions.
# Vygeneruj: `openssl rand -hex 32`
CRON_SECRET=""

# Resend API klíč pro admin e-mail digest (M2+).
RESEND_API_KEY=""
ADMIN_NOTIFICATION_EMAILS="" # čárkou oddělené e-maily adminů
