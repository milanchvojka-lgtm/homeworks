# Postgres připojení (Supabase). Použij "Connection string" z Project Settings → Database.
# Pro server (server actions, cron handlery): pooler URL na portu 6543 s ?pgbouncer=true.
# Pro `prisma migrate` / `db push` / `db:seed`: direct URL na portu 5432.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Vynucuje běh Node procesu v Europe/Prague (důležité pro cron handlery a date-fns).
TZ="Europe/Prague"

# Sdílený secret pro autorizaci HTTPS volání cron endpointů z GitHub Actions.
# Vygeneruj: `openssl rand -hex 32`
CRON_SECRET=""

# Resend API klíč pro admin e-mail digest (M2+).
RESEND_API_KEY=""
ADMIN_NOTIFICATION_EMAILS="" # čárkou oddělené e-maily adminů
